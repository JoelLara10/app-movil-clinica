{
  "expo": {
    "name": "INEO Hospital",
    "slug": "ineo-hospital",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#667eea"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ineo.hospital"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#667eea"
      },
      "package": "com.ineo.hospital"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      /* "API_URL": "http://192.168.1.67:5001/api/v1" */
      "API_URL": "http://10.30.40.67:5001/api/v1"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
